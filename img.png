*{
    padding:0;
    margin:0;
}

body{
    width: 100%;
    height: 100%;
    background-image: url('img.png');
    background-size:cover;
    background-attachment: fixed;
}
.top{
    width:100%;
    display: flex;
    flex-wrap: wrap;
}
.content {
            margin-right: 50px;
            padding-top: 70px;
            text-align: right;
 }
        
p:nth-child(1){
    font-size: 4em;
    font-weight: bold;
    color: #691111;
    text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);
     animation: fadeIn 2s ease-in-out;
        }

@keyframes fadeIn {
            0% { opacity: 0; transform: translateY(-20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
h2{
    font-family: 'Source Code Pro', monospace;
    font-size: 60px;
    color:#691111;
}

p:nth-child(4){
    width: 400px;
    font-size: 16px;
    margin:20px 0px;
}



input[type="file"] {
    padding: 10px;
    margin-bottom: 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    cursor: pointer;
    width: fit-content; /* <-- يجعل الزر بحجم محتواه فقط */
    box-sizing: border-box;
    transition: border-color 0.3s ease;
    margin-right: 50px;
}

input[type="file"]:hover {
            border-color: #691111;
}

button {
    background-color: transparent;  /* خلفية شفافة */
    color: #691111;  /* اللون النصي */
    padding: 5px 5px ;  /* تعديل الحشوات الداخلية لتقليل حجم الزر */
    border: 2px solid #691111;  /* إضافة حدود بحجم 2px */
    border-radius: 8px;  /* تدوير الحواف */
    cursor: pointer;  /* تغيير شكل المؤشر عند المرور */
    transition: all 0.3s ease;  /* تأثير انتقالي عند التفاعل */
    font-size: 14px;  /* تصغير حجم الخط */
    outline: none;  /* إزالة الخط الخارجي عند النقر */
    display: inline-block;  /* الزر لن يأخذ مساحة أكبر من حجمه الطبيعي */
    width: auto;  /* تأكد من أن العرض هو الحجم الطبيعي للزر */6
    height: auto;  /* تأكد من أن الارتفاع هو الحجم الطبيعي للزر */
    min-width: 100px;  /* تحديد الحد الأدنى للعرض */
}

button:hover {
    background-color: #691111;  /* تغيير الخلفية عند التمرير */
    color: #fff;  /* تغيير لون النص إلى الأبيض */
    border-color: #e2a424;  /* تغيير لون الحدود */
}

button:focus {
    border-color: #e2a424;  /* تغيير لون الحدود عند النقر */
    border-width: 2px;  /* زيادة سماكة الحدود عند النقر */
}

/* تصميم قسم عرض التصنيفات */
.classification-container {
    margin-right: 100px;
    margin-bottom: 50px;
    
}




.classification-container h2 {
    margin-top: 0;
    
}



.classification-container ul {
    background-color: #333333; 
    color: #ffffff; 
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
    padding: 40px;  /* زيادة المسافة الداخلية (padding) لتكبير العنصر عموديًا وأفقيًا */
    border-radius: 8px;
    width: 80%;  /* تكبير العرض إلى 80% من العرض الكلي */
    height: 500px;
    max-width: 600px; /* تحديد الحد الأقصى للعرض */
    margin: 0 auto; /* نقل العنصر إلى المنتصف أفقيًا */
    padding-top: 10px;  /* زيادة المسافة العلوية */
    padding-bottom: 30px;  /* زيادة المسافة السفلية */
    margin: 0 auto; /* تمركز العنصر أفقيًا */
    margin-top: -30px; 
}










        
